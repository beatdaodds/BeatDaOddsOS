generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  ARTIST
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  role      Role     @default(ARTIST)
  createdAt DateTime @default(now())
}

model Artist {
  id        String   @id @default(cuid())
  name      String
  listeners String   @default("0")
  status    String   @default("Active")
  imageUrl  String?
  createdAt DateTime @default(now())
}

model Transaction {
  id        String   @id @default(cuid())
  label     String
  amount    Float
  type      String   // "Income" or "Expense"
  date      DateTime @default(now())
}

model Session {
  id        String   @id @default(cuid())
  artist    String
  room      String
  time      String
  date      DateTime @default(now())
}
